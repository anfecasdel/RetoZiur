# ==============================================
#  .gitignore — Proyecto .NET / Blazor (RetoZiur)
# ==============================================

# --- Salidas de compilación (nunca se suben) ---
bin/
obj/
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
out/

# --- Configuración local / SECRETOS (¡importante!) ---
# El appsettings.Development.json puede contener valores locales sensibles.
appsettings.Development.json
appsettings.*.Development.json
secrets.json
*.user
*.userosscache
*.suo

# --- Archivos de usuario / IDE ---
.vs/
.vscode/
.idea/
*.swp
*.DS_Store

# --- Logs y temporales ---
*.log
*.tmp
*.cache

# --- Archivos de trabajo propios (no forman parte de la entrega) ---
context.md
REFACTOR-NOTES.md

# --- Paquetes NuGet restaurados ---
*.nupkg
packages/
project.lock.json
project.fragment.lock.json
artifacts/